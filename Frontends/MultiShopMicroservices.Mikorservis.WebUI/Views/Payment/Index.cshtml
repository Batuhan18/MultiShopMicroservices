
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/UILayout/_UILayout.cshtml";
}


<style>

    body {
        background: #e5e5e5;
        font-family: Arial, Helvetica, sans-serif;
    }

    .payment-container {
        width: 900px;
        margin: auto;
        margin-top: 80px;
        display: flex;
        gap: 40px;
        align-items: center;
        justify-content: center;
    }

    .card-preview {
        width: 360px;
        height: 210px;
        border-radius: 16px;
        background: linear-gradient(135deg,#f7c948,#e0a800);
        color: #333;
        padding: 25px;
        box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        position: relative;
    }

    .card-number {
        font-size: 22px;
        letter-spacing: 3px;
        margin-top: 45px;
        font-weight: bold;
    }

    .card-holder {
        position: absolute;
        bottom: 25px;
        left: 25px;
        font-size: 14px;
        font-weight: bold;
    }

    .card-expiry {
        position: absolute;
        bottom: 25px;
        right: 25px;
        font-size: 14px;
        font-weight: bold;
    }

    .form-area {
        width: 400px;
        background: #f8f9fa;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    .form-group {
        margin-bottom: 18px;
    }

    label {
        font-size: 14px;
        color: #555;
        display: block;
        margin-bottom: 6px;
    }

    input {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 15px;
        transition: all .2s;
    }

        input:focus {
            border-color: #f7c948;
            outline: none;
            box-shadow: 0 0 4px rgba(247,201,72,0.6);
        }

    button {
        width: 100%;
        padding: 12px;
        background: #f7c948;
        border: none;
        color: #333;
        font-size: 16px;
        font-weight: bold;
        border-radius: 6px;
        cursor: pointer;
        transition: 0.2s;
    }

        button:hover {
            background: #e0a800;
        }

</style>

<div class="payment-container">
    <div class="card-preview">

        <div id="cardNumberView" class="card-number">
            #### #### #### ####
        </div>

        <div id="cardHolderView" class="card-holder">
            AD SOYAD
        </div>

        <div id="cardExpiryView" class="card-expiry">
            00/00
        </div>

    </div>

    <div class="form-area">

        <form method="post">

            <div class="form-group">
                <label>Kart Numarası</label>
                <input type="text"
                       maxlength="19"
                       id="cardNumber"
                       placeholder="1234 5678 9012 3456">
            </div>

            <div class="form-group">
                <label>Kart Sahibi</label>
                <input type="text"
                       id="cardHolder"
                       placeholder="Ad Soyad">
            </div>

            <div class="form-group">
                <label>Son Kullanma Tarihi</label>
                <input type="text"
                       maxlength="5"
                       id="cardExpiry"
                       placeholder="MM/YY">
            </div>

            <div class="form-group">
                <label>CVV</label>
                <input type="password"
                       maxlength="3"
                       placeholder="123">
            </div>

            <button type="submit">Ödeme Yap</button>

        </form>

    </div>
    ```

</div>

<script>

    const cardNumberInput = document.getElementById("cardNumber");
    const cardHolderInput = document.getElementById("cardHolder");
    const cardExpiryInput = document.getElementById("cardExpiry");

    const cardNumberView = document.getElementById("cardNumberView");
    const cardHolderView = document.getElementById("cardHolderView");
    const cardExpiryView = document.getElementById("cardExpiryView");

    cardNumberInput.addEventListener("input", function () {

        let value = this.value.replace(/\s/g,'');

        value = value.match(/.{1,4}/g)?.join(" ") || value;

        this.value = value;

        cardNumberView.innerText = value || "#### #### #### ####";

    });

    cardHolderInput.addEventListener("input", function () {

        cardHolderView.innerText = this.value.toUpperCase() || "AD SOYAD";

    });

    cardExpiryInput.addEventListener("input", function () {

        let value = this.value.replace(/\D/g,'');

        if(value.length >=3)
            value = value.slice(0,2) + "/" + value.slice(2);

        this.value = value;

        cardExpiryView.innerText = value || "00/00";

    });

</script>


